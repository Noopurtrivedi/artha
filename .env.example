# Artha environment configuration
# Copy to .env and fill in values. Never commit .env.

# ── LLM Backend ─────────────────────────────────────────────────────────────
# Primary local LLM (Ollama default — no key needed)
ARTHA_LLM_BASE_URL=http://localhost:11434/v1
ARTHA_LLM_MODEL=llama3.2:3b-instruct-q4_K_M

# Cloud fallback (optional — user must opt in per-call)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
ARTHA_LOG_LEVEL=info        # debug | info | warn | error

# ── Docker sandboxing (optional) ────────────────────────────────────────────
# DOCKER_HOST=unix:///var/run/docker.sock
